# ─── App ───────────────────────────────────────────
APP_NAME=RoyyaAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key

# ─── PostgreSQL ────────────────────────────────────
POSTGRES_USER=royyaai
POSTGRES_PASSWORD=royyaai_secret
POSTGRES_DB=royyaai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://royyaai:royyaai_secret@postgres:5432/royyaai_db

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─── JWT ───────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-another-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── LLM Providers ─────────────────────────────────
LLM_PROVIDER=openai             # options: anthropic, openai, deepseek, qwen
ANTHROPIC_API_KEY=
OPENAI_API_KEY=sk-...           # ← put your key here
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ─── Qdrant ────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=royyaai_knowledge

# ─── MinIO ─────────────────────────────────────────
MINIO_ROOT_USER=royyaai_minio
MINIO_ROOT_PASSWORD=royyaai_minio_secret
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=royyaai-files

# ─── Celery ────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Email ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@royyaai.com

# ─── Firebase (Push Notifications) ────────────────
FIREBASE_CREDENTIALS_PATH=./infra/firebase-credentials.json

# ─── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
